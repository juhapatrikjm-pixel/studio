
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Käyttäjän ja yrityksen profiilitiedot",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "workPhone": { "type": "string" },
        "personalPhone": { "type": "string" },
        "address": { "type": "string" },
        "businessId": { "type": "string" },
        "logoUrl": { "type": "string" },
        "moduleOrder": { 
          "type": "array",
          "items": { "type": "string" },
          "description": "Käyttäjän järjestämä moduulijärjestys"
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Sovelluksen globaalit asetukset",
      "type": "object",
      "properties": {
        "targetMargin": { "type": "number" },
        "hourlyRate": { "type": "number" },
        "cheerMessages": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["fi", "en", "sv", "et", "ru"] },
        "currency": { "type": "string", "enum": ["EUR", "USD", "GBP", "SEK", "RUB"] },
        "weightUnit": { "type": "string", "enum": ["kg/g", "lb/oz", "g", "oz"] }
      }
    },
    "WasteGroup": {
      "title": "WasteGroup",
      "description": "Hävikkiryhmät (esim. Kala, Liha)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "index": { "type": "number" }
      }
    },
    "WasteProduct": {
      "title": "WasteProduct",
      "description": "Hävikkiseurannassa käytettävät raaka-aineet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "name": { "type": "string" },
        "pricePerKg": { "type": "number" }
      },
      "required": ["name", "pricePerKg"]
    },
    "WasteEntry": {
      "title": "WasteEntry",
      "description": "Yksittäinen hävikkikirjaus",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "weight": { "type": "number" },
        "cost": { "type": "number" },
        "type": { "type": "string", "enum": ["prep", "waste"] },
        "monthId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "MonthlyWaste": {
      "title": "MonthlyWaste",
      "description": "Kuukausittainen hävikkiyhteenveto",
      "type": "object",
      "properties": {
        "monthId": { "type": "string" },
        "monthName": { "type": "string" },
        "totalWasteCost": { "type": "number" },
        "totalPrepCost": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Käyttäjäprofiilit"
    },
    "/wasteGroups/{groupId}": {
      "schema": "WasteGroup",
      "description": "Hävikkiryhmät"
    },
    "/wasteProducts/{productId}": {
      "schema": "WasteProduct",
      "description": "Hävikkiraaka-aineet"
    },
    "/wasteEntries/{entryId}": {
      "schema": "WasteEntry",
      "description": "Hävikkikirjaukset"
    },
    "/monthlyWaste/{monthId}": {
      "schema": "MonthlyWaste",
      "description": "Kuukausiyhteenvedot"
    },
    "/settings/global": {
      "schema": "AppSetting",
      "description": "Yleiset asetukset"
    }
  }
}
