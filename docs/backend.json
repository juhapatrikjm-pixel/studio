
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Käyttäjän ja yrityksen profiilitiedot",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "workPhone": { "type": "string" },
        "personalPhone": { "type": "string" },
        "address": { "type": "string" },
        "businessId": { "type": "string" },
        "logoUrl": { "type": "string" },
        "moduleOrder": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "role": { "type": "string", "enum": ["admin", "worker"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WasteGroup": {
      "title": "WasteGroup",
      "description": "Hävikkiryhmät (esim. Kala, Liha)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "index": { "type": "number" }
      }
    },
    "WasteProduct": {
      "title": "WasteProduct",
      "description": "Hävikkiraaka-aineet tukkuhinnoilla",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "name": { "type": "string" },
        "pricePerKg": { "type": "number" }
      }
    },
    "WasteEntry": {
      "title": "WasteEntry",
      "description": "Yksittäinen hävikkikirjaus",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "weight": { "type": "number" },
        "cost": { "type": "number" },
        "type": { "type": "string", "enum": ["prep", "waste"] },
        "monthId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ShiftInfo": {
      "title": "ShiftInfo",
      "description": "Päivittäiset INFO-tiedotteet",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "bulletPoints": { "type": "array", "items": { "type": "string" } },
        "freeText": { "type": "string" },
        "acknowledgedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CloudFolder": {
      "title": "CloudFolder",
      "description": "Pilvitallennuksen kansio",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "parentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CloudFile": {
      "title": "CloudFile",
      "description": "Pilvitallennuksen tiedosto",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "size": { "type": "string" },
        "type": { "type": "string" },
        "folderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Käyttäjien profiilit"
    },
    "/wasteGroups/{groupId}": {
      "schema": "WasteGroup",
      "description": "Hävikkiryhmät"
    },
    "/wasteProducts/{productId}": {
      "schema": "WasteProduct",
      "description": "Hävikkiraaka-aineet"
    },
    "/wasteEntries/{entryId}": {
      "schema": "WasteEntry",
      "description": "Hävikkikirjaukset"
    },
    "/monthlyWaste/{monthId}": {
      "schema": "object",
      "description": "Kuukausittaiset hävikkiyhteenvedot"
    },
    "/shiftInfos/{infoId}": {
      "schema": "ShiftInfo",
      "description": "INFO-sivun tiedotteet"
    },
    "/cloudFolders/{folderId}": {
      "schema": "CloudFolder",
      "description": "Pilvitallennuksen kansiot"
    },
    "/cloudFiles/{fileId}": {
      "schema": "CloudFile",
      "description": "Pilvitallennuksen tiedostot"
    },
    "/uploadedRecipes/{fileId}": {
      "schema": "object",
      "description": "Arkistoon ladatut reseptitiedostot"
    },
    "/maintenanceNotes/{noteId}": {
      "schema": "object",
      "description": "Huoltopyynnöt ja huomiot"
    }
  }
}
