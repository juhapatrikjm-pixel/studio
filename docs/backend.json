
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Käyttäjän ja yrityksen profiilitiedot",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "workPhone": { "type": "string" },
        "personalPhone": { "type": "string" },
        "address": { "type": "string" },
        "businessId": { "type": "string" },
        "logoUrl": { "type": "string" },
        "moduleOrder": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "role": { "type": "string", "enum": ["admin", "worker"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WasteGroup": {
      "title": "WasteGroup",
      "description": "Hävikkiryhmät (esim. Kala, Liha)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "index": { "type": "number" }
      }
    },
    "WasteProduct": {
      "title": "WasteProduct",
      "description": "Hävikkiraaka-aineet tukkuhinnoilla",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "groupId": { "type": "string" },
        "name": { "type": "string" },
        "pricePerKg": { "type": "number" }
      }
    },
    "WasteEntry": {
      "title": "WasteEntry",
      "description": "Yksittäinen hävikkikirjaus",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "weight": { "type": "number" },
        "cost": { "type": "number" },
        "type": { "type": "string", "enum": ["prep", "waste"] },
        "monthId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "ShiftInfo": {
      "title": "ShiftInfo",
      "description": "Päivittäiset INFO-tiedotteet",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "bulletPoints": { "type": "array", "items": { "type": "string" } },
        "freeText": { "type": "string" },
        "acknowledgedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "OnboardingTask": {
      "title": "OnboardingTask",
      "description": "Perehdytystehtävä",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "anonymous"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Käyttäjien profiilit"
    },
    "/wasteGroups/{groupId}": {
      "schema": "WasteGroup",
      "description": "Hävikkiryhmät"
    },
    "/wasteProducts/{productId}": {
      "schema": "WasteProduct",
      "description": "Hävikkiraaka-aineet"
    },
    "/wasteEntries/{entryId}": {
      "schema": "WasteEntry",
      "description": "Hävikkikirjaukset"
    },
    "/monthlyWaste/{monthId}": {
      "schema": "object",
      "description": "Kuukausittaiset hävikkiyhteenvedot"
    },
    "/shiftInfos/{infoId}": {
      "schema": "ShiftInfo",
      "description": "INFO-sivun tiedotteet"
    },
    "/onboardingTasks/{taskId}": {
      "schema": "OnboardingTask",
      "description": "Perehdytyslistan tehtävät"
    },
    "/onboardingProgress/{progressId}": {
      "schema": "object",
      "description": "Käyttäjien perehdytymisen edistyminen"
    },
    "/onboardingMeta/{catId}": {
      "schema": "object",
      "description": "Perehdytyskategorioiden tavoitteet ja kysymykset"
    },
    "/recipes/{recipeId}": {
      "schema": "object",
      "description": "Reseptikirjasto"
    },
    "/dishes/{dishId}": {
      "schema": "object",
      "description": "Annoskortit"
    },
    "/financialRecords/{recordId}": {
      "schema": "object",
      "description": "Tulos-sivun talousdatan kirjaukset"
    },
    "/maintenanceNotes/{noteId}": {
      "schema": "object",
      "description": "Huoltopyynnöt ja ilmoitukset"
    },
    "/todoTasks/{taskId}": {
      "schema": "object",
      "description": "Yleinen tehtävälista"
    },
    "/calendarEvents/{eventId}": {
      "schema": "object",
      "description": "Kalenterimerkinnät"
    },
    "/suppliers/{supplierId}": {
      "schema": "object",
      "description": "Toimittajarekisteri"
    },
    "/orders/{orderId}": {
      "schema": "object",
      "description": "Tilausseuranta"
    },
    "/settings/global": {
      "schema": "object",
      "description": "Keittiön globaalit asetukset"
    }
  }
}
