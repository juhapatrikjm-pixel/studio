
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Käyttäjän ja yrityksen profiilitiedot",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "userName": { "type": "string" },
        "title": { "type": "string" },
        "workPhone": { "type": "string" },
        "personalPhone": { "type": "string" },
        "address": { "type": "string" },
        "businessId": { "type": "string" },
        "logoUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "MisaList": {
      "title": "MisaList",
      "description": "Keittiön prep- ja valmistelulistat",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "completed": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["title"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Tukkutoimittajat ja yhteistyökumppanit",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "Order": {
      "title": "Order",
      "description": "Tehdyt tilaukset ja toimitukset",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "color": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "arrivalDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "shipped", "arrived"] }
      }
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Keittiön laitekanta",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" }
      }
    },
    "MaintenanceNote": {
      "title": "MaintenanceNote",
      "description": "Huoltoilmoitukset ja muistiinpanot",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved"] }
      },
      "required": ["text"]
    },
    "MaintenanceContact": {
      "title": "MaintenanceContact",
      "description": "Huoltoliikkeiden yhteystiedot",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "ArchiveFolder": {
      "title": "ArchiveFolder",
      "description": "Arkiston kansiorakenne",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["recipes", "dishes", "uploads"] },
        "parentId": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "Recipe": {
      "title": "Recipe",
      "description": "Keittiön reseptit",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "portions": { "type": "number" },
        "folderId": { "type": "string" },
        "ingredients": { "type": "array" },
        "steps": { "type": "array" },
        "equipment": { "type": "array" },
        "calculations": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Dish": {
      "title": "Dish",
      "description": "Koostetut annokset",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sellingPrice": { "type": "number" },
        "recipes": { "type": "array" },
        "totalCost": { "type": "number" },
        "margin": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Sovelluksen yleiset asetukset",
      "type": "object",
      "properties": {
        "targetMargin": { "type": "number" },
        "hourlyRate": { "type": "number", "description": "Tuntipalkka kuluineen" },
        "cheerMessages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ShiftInfo": {
      "title": "ShiftInfo",
      "description": "Vuorokohtaiset merkinnät ja tiedotteet",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bulletPoints": { "type": "array", "items": { "type": "string" } },
        "freeText": { "type": "string" },
        "acknowledgedBy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "FinancialRecord": {
      "title": "FinancialRecord",
      "description": "Päivittäiset talousluvut",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "revenue": { "type": "number" },
        "foodCost": { "type": "number" },
        "laborCost": { "type": "number" },
        "workHours": { "type": "number" },
        "otherExpenses": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "revenue"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Kalenterimerkinnät ja muistutukset",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "alert": { "type": "boolean" }
      }
    },
    "TodoTask": {
      "title": "TodoTask",
      "description": "Yleiset tehtävälistat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Käyttäjäprofiilit"
    },
    "/misaLists/{listId}": {
      "schema": "MisaList",
      "description": "Prep-listat"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Toimittajat"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Tilaukset"
    },
    "/equipment/{equipId}": {
      "schema": "Equipment",
      "description": "Laitteet"
    },
    "/maintenanceNotes/{noteId}": {
      "schema": "MaintenanceNote",
      "description": "Huoltoilmoitukset"
    },
    "/archiveFolders/{folderId}": {
      "schema": "ArchiveFolder",
      "description": "Arkistokansiot"
    },
    "/recipes/{recipeId}": {
      "schema": "Recipe",
      "description": "Reseptit"
    },
    "/dishes/{dishId}": {
      "schema": "Dish",
      "description": "Annokset"
    },
    "/settings/global": {
      "schema": "AppSetting",
      "description": "Yleiset asetukset"
    },
    "/shiftInfos/{infoId}": {
      "schema": "ShiftInfo",
      "description": "Vuorokohtaiset merkinnät"
    },
    "/financialRecords/{recordId}": {
      "schema": "FinancialRecord",
      "description": "Päivittäiset talousmerkinnät"
    },
    "/calendarEvents/{eventId}": {
      "schema": "CalendarEvent",
      "description": "Kalenteritapahtumat"
    },
    "/todoTasks/{taskId}": {
      "schema": "TodoTask",
      "description": "Yleiset tehtävät"
    }
  }
}
